{
    "version": "0.1.0",
    "scripts": {
        "build": "rollup -c",
        "dev": "npm-run-all plugin:unlink plugin:link -p plugin:watch plugin:debug",
        "plugin:watch": "rollup -c -w --watch.onEnd=\"npm run plugin:restart\"",
        "plugin:unlink": "flexcli plugin unlink --uuid dev.sese.flexbar_claude_code_usage --silent",
        "plugin:link": "flexcli plugin link --path dev.sese.flexbar_claude_code_usage.plugin --uuid dev.sese.flexbar_claude_code_usage --start false",
        "plugin:restart": "flexcli plugin restart --uuid=dev.sese.flexbar_claude_code_usage",
        "plugin:debug": "flexcli plugin debug --uuid=dev.sese.flexbar_claude_code_usage",
        "plugin:validate": "flexcli plugin validate --path dev.sese.flexbar_claude_code_usage.plugin",
        "plugin:pack": "flexcli plugin pack --path dev.sese.flexbar_claude_code_usage.plugin",
        "plugin:install": "flexcli plugin install --path ./dev.sese.flexbar_claude_code_usage.flexplugin --force",
        "format": "eslint --fix \"src/**/*.ts\""
    },
    "type": "commonjs",
    "dependencies": {
        "@eniac/flexdesigner": "^1.0.1",
        "@napi-rs/canvas": "^0.1.52"
    },
    "devDependencies": {
        "@eniac/flexcli": "^1.0.6",
        "@eslint/js": "^9.26.0",
        "typescript-eslint": "^8.32.0",
        "@rollup/plugin-commonjs": "^28.0.0",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^15.2.2",
        "@rollup/plugin-terser": "^0.4.4",
        "@rollup/plugin-typescript": "^12.1.2",
        "@types/node": "^22.15.3",
        "@typescript-eslint/eslint-plugin": "^8.32.0",
        "@typescript-eslint/parser": "^8.32.0",
        "eslint": "^9.26.0",
        "eslint-config-prettier": "^10.1.2",
        "eslint-import-resolver-typescript": "^4.3.4",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-prettier": "^5.4.0",
        "eslint-plugin-unused-imports": "^4.1.4",
        "glob": "^11.0.1",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.5.3",
        "rollup": "^4.0.2",
        "tslib": "^2.8.1",
        "typescript": "^5.8.3"
    }
}
